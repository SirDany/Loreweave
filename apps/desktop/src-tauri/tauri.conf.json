{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loreweave",
  "version": "0.1.0",
  "identifier": "com.loreweave.app",
  "build": {
    "beforeDevCommand": "pnpm -w dev:web",
    "beforeBuildCommand": "pnpm -w build:all && node ../../scripts/stage-desktop-resources.mjs",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "./resources/web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Loreweave",
        "width": 1400,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "center": true,
        "url": "splash.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/**/*"],
    "externalBin": ["binaries/lw-node"],
    "publisher": "Loreweave",
    "category": "Productivity",
    "shortDescription": "Local-first agentic book-writing workbench.",
    "longDescription": "Loreweave is a local-first writing workbench: your canon lives as plain Markdown and YAML, the CLI gives you ground-truth queries, the web UI navigates your world, and Copilot agents help you draft without rewriting your story behind your back."
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [
        "https://github.com/SirDany/Loreweave/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBKEY"
    }
  }
}
