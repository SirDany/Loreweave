{
  "name": "loreweave",
  "version": "0.1.0",
  "private": true,
  "description": "Agentic book-writing workbench: markdown + YAML canon, Copilot agents, desktop UI.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "test": "pnpm -r --filter \"./packages/*\" test",
    "typecheck": "pnpm -r --filter \"./packages/*\" typecheck",
    "lw": "pnpm --filter @loreweave/cli start --",
    "dev:desktop": "pnpm --filter @loreweave/desktop dev"
  },
  "devDependencies": {
    "typescript": "5.6.2"
  }
}
