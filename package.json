{
  "name": "loreweave",
  "version": "0.1.0",
  "private": true,
  "description": "Agentic book-writing workbench: markdown + YAML canon, Copilot agents, local-first web UI.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "build:all": "pnpm -r --filter \"./packages/*\" build && pnpm --filter @loreweave/web build",
    "test": "pnpm -r --filter \"./packages/*\" test",
    "typecheck": "pnpm -r --filter \"./packages/*\" typecheck",
    "lw": "pnpm --filter @loreweave/cli start --",
    "start": "node scripts/launch.mjs",
    "dev": "pnpm --filter @loreweave/web dev",
    "dev:web": "pnpm --filter @loreweave/web dev",
    "desktop": "pnpm --filter @loreweave/desktop dev",
    "desktop:build": "pnpm build:all && node scripts/stage-desktop-resources.mjs && node scripts/fetch-desktop-node.mjs && pnpm --filter @loreweave/desktop build"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
