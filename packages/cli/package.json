{
  "name": "@loreweave/cli",
  "version": "0.1.0",
  "description": "Loreweave CLI: validate, resolve, refs, audit, thread, calendar.",
  "type": "module",
  "bin": {
    "lw": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/bin.js"
  },
  "dependencies": {
    "@loreweave/core": "workspace:*",
    "archiver": "7.0.1",
    "commander": "14.0.3",
    "mammoth": "1.12.0",
    "marked": "18.0.2",
    "pdf-parse": "2.4.5",
    "picocolors": "1.1.1",
    "yaml": "2.8.3",
    "yauzl": "3.3.0"
  },
  "devDependencies": {
    "@types/archiver": "7.0.0",
    "@types/node": "22.12.0",
    "@types/pdf-parse": "1.1.4",
    "@types/yauzl": "2.10.3",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
